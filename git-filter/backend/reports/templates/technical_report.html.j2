<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Technical Report — {{ repo_name }}</title>
  <style>
    :root { --accent: #2563eb; --danger: #dc2626; --warn: #d97706; --bg: #f8fafc; }
    body { font-family: 'Segoe UI', system-ui, sans-serif; background: var(--bg); color: #1e293b; margin: 0; padding: 2rem; }
    h1 { color: var(--accent); border-bottom: 3px solid var(--accent); padding-bottom: .5rem; }
    h2 { color: #334155; border-left: 4px solid var(--accent); padding-left: .75rem; margin-top: 2rem; }
    h3 { color: #475569; }
    .meta { background: #fff; border: 1px solid #e2e8f0; border-radius: 8px; padding: 1rem 1.5rem; margin: 1.5rem 0; }
    .meta p { margin: .25rem 0; font-size: .9rem; color: #64748b; }
    .meta strong { color: #1e293b; }
    table { width: 100%; border-collapse: collapse; margin: 1rem 0; }
    th { background: var(--accent); color: #fff; text-align: left; padding: .6rem 1rem; font-size: .85rem; }
    td { padding: .55rem 1rem; border-bottom: 1px solid #e2e8f0; font-size: .85rem; }
    tr:hover td { background: #f1f5f9; }
    .badge { display: inline-block; padding: 2px 8px; border-radius: 9999px; font-size: .75rem; font-weight: 600; }
    .badge-ui { background: #dbeafe; color: #1d4ed8; }
    .badge-backend { background: #dcfce7; color: #166534; }
    .badge-utils { background: #f3f4f6; color: #374151; }
    .badge-config { background: #fef9c3; color: #854d0e; }
    .badge-tests { background: #f3e8ff; color: #7e22ce; }
    .badge-external { background: #ffedd5; color: #9a3412; }
    .risk-high { color: var(--danger); font-weight: 700; }
    .risk-mid { color: var(--warn); font-weight: 600; }
    .summary-box { background: #fff; border: 1px solid #e2e8f0; border-radius: 8px; padding: 1.25rem 1.5rem; margin: 1rem 0; line-height: 1.7; }
    .onboarding-step { display: flex; gap: 1rem; align-items: flex-start; margin: .75rem 0; padding: .75rem; background: #fff; border: 1px solid #e2e8f0; border-radius: 8px; }
    .step-num { background: var(--accent); color: #fff; border-radius: 50%; width: 2rem; height: 2rem; display: flex; align-items: center; justify-content: center; font-weight: 700; flex-shrink: 0; font-size: .85rem; }
    .orphan-list li, .hotzone-list li { font-size: .875rem; padding: .2rem 0; }
    footer { margin-top: 3rem; border-top: 1px solid #e2e8f0; padding-top: 1rem; color: #94a3b8; font-size: .8rem; text-align: center; }
  </style>
</head>
<body>

<h1>🔍 Technical Architecture Report</h1>
<h2 style="border:none;padding:0;margin-top:0;font-size:1.1rem;color:#64748b;">{{ repo_url }}</h2>

<div class="meta">
  <p><strong>Repository:</strong> {{ owner }}/{{ repo }}</p>
  <p><strong>Analysis Timestamp:</strong> {{ generated_at }}</p>
  <p><strong>Total Files Analyzed:</strong> {{ stats.total_nodes }}</p>
  <p><strong>Total Dependencies Mapped:</strong> {{ stats.total_edges }}</p>
  <p><strong>Languages:</strong> {{ languages_str }}</p>
</div>

<!-- Graph Statistics -->
<h2>📊 Architecture Graph Statistics</h2>
<table>
  <tr><th>Metric</th><th>Value</th></tr>
  <tr><td>Total Nodes (Files)</td><td>{{ stats.total_nodes }}</td></tr>
  <tr><td>Total Edges (Dependencies)</td><td>{{ stats.total_edges }}</td></tr>
  <tr><td>Average In-Degree</td><td>{{ stats.avg_in_degree }}</td></tr>
  <tr><td>Average Out-Degree</td><td>{{ stats.avg_out_degree }}</td></tr>
  <tr><td>Isolated Components</td><td>{{ stats.isolated_components }}</td></tr>
  <tr><td>High-Impact Files</td><td>{{ stats.high_impact_count }}</td></tr>
  <tr><td>Orphaned Modules</td><td>{{ stats.orphan_count }}</td></tr>
  <tr><td>Predicted Hot Zones</td><td>{{ stats.hot_zone_count }}</td></tr>
</table>

<!-- Section Breakdown -->
<h2>🗂️ Section Breakdown</h2>
<table>
  <tr><th>Section</th><th>File Count</th></tr>
  {% for section, count in sections.items() %}
  <tr>
    <td><span class="badge badge-{{ section.lower() }}">{{ section }}</span></td>
    <td>{{ count }}</td>
  </tr>
  {% endfor %}
</table>

<!-- High-Impact Files -->
<h2>⚡ High-Impact Files</h2>
<table>
  <tr><th>File</th><th>Section</th><th>Impact Score</th><th>Churn Score</th><th>In-Degree</th></tr>
  {% for node in high_impact_nodes[:20] %}
  <tr>
    <td style="font-family:monospace;font-size:.8rem;">{{ node.id }}</td>
    <td><span class="badge badge-{{ node.section.lower() }}">{{ node.section }}</span></td>
    <td class="{% if node.impact_score > 85 %}risk-high{% elif node.impact_score > 70 %}risk-mid{% endif %}">{{ "%.1f"|format(node.impact_score) }}</td>
    <td>{{ "%.1f"|format(node.churn_score) }}</td>
    <td>{{ node.depended_on_by|length }}</td>
  </tr>
  {% endfor %}
</table>

<!-- Orphaned Modules -->
<h2>🔌 Orphaned Modules</h2>
{% if orphan_paths %}
<ul class="orphan-list">
  {% for path in orphan_paths %}
  <li><code>{{ path }}</code></li>
  {% endfor %}
</ul>
{% else %}
<p>No orphaned modules detected.</p>
{% endif %}

<!-- Hot Zones -->
<h2>🔥 Predicted Hot Zones</h2>
{% if hot_zone_nodes %}
<table>
  <tr><th>File</th><th>Hot Zone Score</th><th>Bug Commit Ratio</th><th>Churn Score</th></tr>
  {% for node in hot_zone_nodes[:15] %}
  <tr>
    <td style="font-family:monospace;font-size:.8rem;">{{ node.id }}</td>
    <td class="risk-high">{{ "%.1f"|format(node.hot_zone_score) }}</td>
    <td>{{ "%.1%"|format(node.bug_commit_ratio) }}</td>
    <td>{{ "%.1f"|format(node.churn_score) }}</td>
  </tr>
  {% endfor %}
</table>
{% else %}
<p>No predicted hot zones detected.</p>
{% endif %}

<!-- Onboarding Path -->
<h2>🗺️ Recommended Onboarding Path</h2>
{% for i, step in onboarding_path[:20] %}
<div class="onboarding-step">
  <div class="step-num">{{ loop.index }}</div>
  <div>
    <strong style="font-family:monospace;font-size:.85rem;">{{ step.file_path }}</strong>
    <span class="badge badge-{{ step.section.lower() }}" style="margin-left:.5rem;">{{ step.section }}</span>
    <p style="margin:.25rem 0;font-size:.85rem;color:#475569;">{{ step.reason }}</p>
    {% if step.ai_summary_excerpt %}
    <p style="margin:.2rem 0;font-size:.8rem;color:#94a3b8;font-style:italic;">{{ step.ai_summary_excerpt[:150] }}</p>
    {% endif %}
  </div>
</div>
{% endfor %}

<!-- AI Summary -->
<h2>🤖 AI-Generated Technical Summary</h2>
<div class="summary-box">{{ ai_summary_text | replace('\n', '<br>') | safe }}</div>

<footer>
  Generated by git-filter | {{ generated_at }} | For internal engineering use.
</footer>
</body>
</html>
